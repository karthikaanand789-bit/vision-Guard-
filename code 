# main.py
from kivy.app import App
from kivy.uix.image import Image
from kivy.uix.boxlayout import BoxLayout
from kivy.uix.label import Label
from kivy.clock import Clock
from kivy.graphics.texture import Texture
from kivy.utils import platform
import cv2
import numpy as np


class VisionGuardApp(App):
    def build(self):
        self.root_layout = BoxLayout(orientation='vertical')
        self.img = Image(allow_stretch=True, keep_ratio=True)
        self.status = Label(text='Initializing...', size_hint_y=0.1)
        self.root_layout.add_widget(self.img)
        self.root_layout.add_widget(self.status)

        self.capture = None
        self.permission_granted = False
        self._update_event = None

        if platform == 'android':
            from android.permissions import (
                request_permissions, Permission, check_permission
            )
            if check_permission(Permission.CAMERA):
                self.permission_granted = True
                self._start_camera()
            else:
                def _cb(perms, grants):
                    # Marshal back onto Kivy's main thread
                    Clock.schedule_once(
                        lambda dt: self._on_permission_result(perms, grants), 0
                    )
                request_permissions([Permission.CAMERA], _cb)
        else:
            # Desktop / dev
            self.permission_granted = True
            self._start_camera()

        return self.root_layout

    # --- Permissions ---
    def _on_permission_result(self, permissions, grants):
        if all(grants):
            self.permission_granted = True
            self._start_camera()
        else:
            self.status.text = 'Camera permission denied'

    # --- Camera ---
    def _start_camera(self):
        if self.capture is not None:
            return

        # Try a few backends / indices
        candidates = []
        if platform == 'android':
            candidates = [(0, cv2.CAP_ANDROID), (1, cv2.CAP_ANDROID)]
        else:
            candidates = [(0, cv2.CAP_ANY), (1, cv2.CAP_ANY)]

        for index, backend in candidates:
            cap = cv2.VideoCapture(index, backend)
            if cap is not None and cap.isOpened():
                self.capture = cap
                break
            if cap is not None:
                cap.release()

        if self.capture is None:
            self.status.text = 'Could not open camera'
            return

        self.status.text = 'Camera running'
        # ~30 FPS
        self._update_event = Clock.schedule_interval(self.update, 1.0 / 30.0)

    # --- Frame loop ---
    def update(self, dt):
        if self.capture is None:
            return

        ret, frame = self.capture.read()
        if not ret or frame is None:
            return

        # --- Lens / circle detection ---
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        gray = cv2.medianBlur(gray, 5)

        circles = cv2.HoughCircles(
            gray,
            cv2.HOUGH_GRADIENT,
            dp=1.2,
            minDist=80,
            param1=100,
            param2=40,
            minRadius=15,
            maxRadius=120,
        )

        count = 0
        if circles is not None:
            circles = np.uint16(np.around(circles[0, :]))
            count = len(circles)
            for (x, y, r) in circles:
                cv2.circle(frame, (x, y), r, (0, 255, 0), 2)
                cv2.circle(frame, (x, y), 2, (0, 0, 255), 3)

        cv2.putText(
            frame,
            f'Lenses: {count}',
            (10, 30),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.7,
            (255, 255, 255),
            2,
        )

        # --- Convert BGR frame to Kivy texture ---
        buf = cv2.flip(frame, 0).tobytes()
        texture = Texture.create(
            size=(frame.shape[1], frame.shape[0]), colorfmt='bgr'
        )
        texture.blit_buffer(buf, colorfmt='bgr', bufferfmt='ubyte')
        self.img.texture = texture

    # --- Lifecycle ---
    def on_pause(self):
        # Required on Android to keep app alive when backgrounded
        if self._update_event is not None:
            self._update_event.cancel()
            self._update_event = None
        if self.capture is not None:
            self.capture.release()
            self.capture = None
        return True

    def on_resume(self):
        if self.permission_granted and self.capture is None:
            self._start_camera()

    def on_stop(self):
        print('Stopping app - releasing camera')
        if self._update_event is not None:
            self._update_event.cancel()
            self._update_event = None
        if self.capture is not None:
            self.capture.release()
            self.capture = None


if __name__ == '__main__':
    VisionGuardApp().run()
